@model KutuphaneProjesi.Models.OduncIslem

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white p-3">
            <h4 class="mb-0 text-center"><i class="fa-solid fa-bolt me-2"></i>Hızlı Ödünç Paneli</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Öğrenci Ara (İsim veya Okul No)</label>
                    <select asp-for="OgrenciId" class="form-control select-ara" asp-items="ViewBag.OgrenciId">
                        <option value="">Öğrenci adını veya numarasını yazın...</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Kitap Ara (İsim veya Yazar)</label>
                    <select asp-for="KitapId" class="form-control select-ara" asp-items="ViewBag.KitapId">
                        <option value="">Kitap adını veya yazarını yazın...</option>
                    </select>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                        <i class="fa-solid fa-check me-2"></i>Ödünç Ver
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.select-ara').select2({
                theme: 'bootstrap-5',
                placeholder: 'Seçmek için yazmaya başlayın...',
                allowClear: true
            });
        });
    </script>
}