@{
    ViewData["Title"] = "Kütüphane İstatistikleri";
    // Eğer null gelirse 0 varsayalım (Hata almamak için koruma)
    var kitapSayisi = ViewBag.KitapSayisi ?? 0;
    var ogrenciSayisi = ViewBag.OgrenciSayisi ?? 0;
    var aktifOdunc = ViewBag.AktifOduncSayisi ?? 0;
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="fa-solid fa-chart-line me-2 text-primary"></i>Genel Bakış</h2>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card bg-primary text-white shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Toplam Kitap</h6>
                            <h2 class="display-5 fw-bold mb-0">@kitapSayisi</h2>
                        </div>
                        <i class="fa-solid fa-book fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card bg-success text-white shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Kayıtlı Öğrenci</h6>
                            <h2 class="display-5 fw-bold mb-0">@ogrenciSayisi</h2>
                        </div>
                        <i class="fa-solid fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card bg-warning text-dark shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-1 opacity-75">Aktif Ödünç</h6>
                            <h2 class="display-5 fw-bold mb-0">@aktifOdunc</h2>
                        </div>
                        <i class="fa-solid fa-hand-holding-hand fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 p-4 bg-light rounded border">
        <h5 class="fw-bold"><i class="fa-solid fa-circle-info me-2 text-info"></i>Sistem Durumu</h5>
        <p class="mb-0 text-muted">Veriler veritabanından anlık olarak çekilmektedir. Son güncelleme: @DateTime.Now.ToString("HH:mm")</p>
    </div>
</div>