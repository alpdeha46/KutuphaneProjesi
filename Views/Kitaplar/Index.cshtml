@model IEnumerable<KutuphaneProjesi.Models.Kitap>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="fa-solid fa-book me-2"></i>Kitap Envanteri</h2>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">+ Yeni Kitap</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="searchString" class="form-control" 
                           placeholder="Kitap adı veya yazar ara..." value="@ViewData["CurrentFilter"]">
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary fw-bold">Ara</button>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Hata"] != null) { <div class="alert alert-danger">@TempData["Hata"]</div> }
    @if (TempData["Mesaj"] != null) { <div class="alert alert-success">@TempData["Mesaj"]</div> }

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Kitap Adı</th>
                    <th>Yazar</th>
                    <th>Kategori</th>
                    <th class="text-center">Stok</th>
                    <th class="text-center">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Ad</td>
                        <td>@item.Yazar</td>
                        <td><span class="badge bg-info text-dark">@item.Kategori?.Ad</span></td>
                        <td class="text-center">@item.StokAdedi</td>
                        <td class="text-center">
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Silinsin mi?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Aranan kriterlere uygun kitap bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>