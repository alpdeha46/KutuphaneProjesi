@model IEnumerable<KutuphaneProjesi.Models.Kategori>

@{
    ViewData["Title"] = "Kategoriler";
}

<h2>Kategoriler</h2>

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-success">@TempData["Mesaj"]</div>
}

@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}

<form asp-action="Create" method="post" class="mb-4">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-6">
            <input name="Ad" class="form-control" placeholder="Kategori adı girin" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-success">Kategori Ekle</button>
        </div>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Kategori Adı</th>
            <th>Kitap Sayısı</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var kategori in Model)
        {
            <tr>
                <td>@kategori.Id</td>
                <td>@kategori.Ad</td>
                <td>@(kategori.Kitaplar?.Count ?? 0)</td>
                <td>
                    <form asp-action="Delete" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@kategori.Id" />
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Bu kategoriyi silmek istiyor musun?')">
                            Sil
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>