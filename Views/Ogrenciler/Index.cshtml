@model IEnumerable<KutuphaneProjesi.Models.Ogrenci>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary">Öğrenci Yönetimi</h2>
        <a asp-action="Create" class="btn btn-success fw-bold">+ Yeni Öğrenci</a>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchString" class="form-control" placeholder="Ad, soyad veya okul no ile ara..." value="@ViewData["CurrentFilter"]">
            <button class="btn btn-primary" type="submit">Ara</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
        </div>
    </form>

    <table class="table table-hover bg-white shadow-sm rounded">
        <thead class="table-dark">
            <tr>
                <th>Okul No</th>
                <th>Ad Soyad</th>
                <th>Sınıf</th>
                <th class="text-center">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OkulNo</td>
                    <td>@item.Ad @item.Soyad</td>
                    <td>@item.Sinif?.Seviye-@item.Sinif?.Sube</td>
                    <td class="text-center">
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Öğrenciyi silmek istediğine emin misin?');">
                            <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>