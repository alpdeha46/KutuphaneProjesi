@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="p-2 mb-4 bg-dark text-white rounded-3 shadow">
    <div class="container-fluid py-5 text-center">
        <h1 class="display-5 fw-bold"><i class="fa-solid fa-book-bookmark text-warning"></i> Kütüphane Otomasyonu</h1>
        <p class="fs-4">Hoş geldiniz! Kitap ödünç verme, öğrenci takibi ve stok yönetimini buradan yapabilirsiniz.</p>
    </div>
</div>

<div class="row text-center">
    <div class="col-md-4">
        <div class="card p-4 bg-primary text-white">
            <h3><i class="fa-solid fa-book fa-2x"></i></h3>
            <h4>Kitaplar</h4>
            <a asp-controller="Kitaplar" asp-action="Index" class="btn btn-light btn-sm mt-2">Yönet</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 bg-success text-white">
            <h3><i class="fa-solid fa-graduation-cap fa-2x"></i></h3>
            <h4>Öğrenciler</h4>
            <a asp-controller="Ogrenciler" asp-action="Index" class="btn btn-light btn-sm mt-2">Yönet</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 bg-warning text-dark">
            <h3><i class="fa-solid fa-clock-rotate-left fa-2x"></i></h3>
            <h4>İşlemler</h4>
            <a asp-controller="Odunc" asp-action="Index" class="btn btn-dark btn-sm mt-2">Hemen Ödünç Ver</a>
        </div>
    </div>
</div>