@model IEnumerable<KutuphaneProjesi.Models.Sinif>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
        <div>
            <h2 class="fw-bold mb-0 text-primary">Sınıf Yönetimi</h2>
            <small class="text-muted">Toplam @Model.Count() sınıf tanımlı</small>
        </div>
        <div class="d-flex gap-2">
            <form asp-action="SinifAtlat" asp-controller="Siniflar" method="post">
                <button type="submit" class="btn btn-warning fw-bold shadow-sm"
                        onclick="return confirm('Tüm sınıfları bir üst seviyeye taşımak istediğinize emin misiniz?')">
                    🚀 Sınıf Atlat (Toplu İşlem)
                </button>
            </form>
            <button class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#yeniSinifModal"><i
                class="fa-solid fa-plus me-1"></i>Yeni Sınıf</button>
            </div>
        </div>

        @if (TempData["Hata"] != null)
        {
            <div class="alert alert-danger shadow-sm">@TempData["Hata"]</div>
        }
        @if (TempData["Mesaj"] != null)
        {
            <div class="alert alert-success shadow-sm">@TempData["Mesaj"]</div>
        }

        <div class="row">
            @foreach (var item in Model.OrderBy(s => s.Seviye))
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0 border-top border-4 border-primary text-center">
                        <div class="card-body py-4">
                            <div class="display-5 fw-bold">@item.Seviye</div>
                            <div class="h5 text-muted mb-3">@item.Sube Şubesi</div>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="/api/SinifApi/@item.Id" target="_blank"
                                   class="btn btn-sm btn-outline-secondary">API</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Sınıfı silmek istediğine emin misin?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                        class="fa-solid fa-trash"></i> Sil</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="modal fade" id="yeniSinifModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content shadow-lg border-0">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title fw-bold">Yeni Sınıf Kaydı</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Create" method="post">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Sınıf Seviyesi (1-12)</label>
                                <select name="Seviye" class="form-select border-primary" required>
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i">@i. Sınıf</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Şube</label>
                                <input type="text" name="Sube" class="form-control border-primary" placeholder="Örn: A" required
                                       maxlength="10" />
                            </div>
                        </div>
                        <div class="modal-footer bg-light border-0">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">KAYDET</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>